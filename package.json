{
  "name": "react-qr-lite",
  "version": "1.0.0",
  "description": "Fast, tiny QR code generator for React (SVG). Zero dependencies.",
  "license": "MIT",
  "author": "yama-io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yama-io/react-qr-lite.git"
  },
  "homepage": "https://github.com/yama-io/react-qr-lite#readme",
  "bugs": {
    "url": "https://github.com/yama-io/react-qr-lite/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "size": "size-limit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build && npm run size"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsqr": "^1.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "size-limit": "^11.1.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "size-limit": [
    {
      "name": "core (encoder only)",
      "path": "dist/core/index.js",
      "limit": "5 KB"
    },
    {
      "name": "full (QRCode component)",
      "path": "dist/index.js",
      "limit": "6 KB",
      "ignore": [
        "react",
        "react/jsx-runtime"
      ]
    }
  ],
  "keywords": [
    "qr",
    "qrcode",
    "qr-code",
    "react",
    "svg",
    "generator",
    "lightweight"
  ]
}
